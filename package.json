{
  "name": "simpletranslator",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:localhost": "expo start --localhost",
    "start:tunnel": "expo start --tunnel",
    "start:clear": "expo start --lan --clear",
    "fix:locks": "powershell -ExecutionPolicy Bypass -File scripts/fix-locks.ps1",
    "fix:git:acl:admin": "powershell -ExecutionPolicy Bypass -File scripts/fix-git-acl-admin.ps1",
    "build:release:apk": "powershell -ExecutionPolicy Bypass -File scripts/release-apk.ps1"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.3",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-pager-view": "6.9.1",
    "react-native-safe-area-context": "^5.7.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
